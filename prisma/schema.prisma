generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Session {
  id            String    @id @db.VarChar(255)
  shop          String    @db.VarChar(100)
  state         String    @db.VarChar(255)
  isOnline      Boolean   @default(false)
  scope         String?   @db.VarChar(255)
  expires       DateTime?
  accessToken   String    @db.VarChar(255)
  userId        BigInt?
  firstName     String?   @db.VarChar(100)
  lastName      String?   @db.VarChar(100)
  email         String?   @db.VarChar(255)
  accountOwner  Boolean   @default(false)
  locale        String?   @db.VarChar(10)
  collaborator  Boolean?  @default(false)
  emailVerified Boolean?  @default(false)
  refreshToken        String?  @db.VarChar(255)
  refreshTokenExpires DateTime?
}

model GatewayCredentials {
  id                  Int       @id @default(autoincrement())
  shop                String    @unique @db.VarChar(100)
  username            String    @db.VarChar(100)
  password            String    @db.VarChar(500)
  senderId            String    @default("") @db.VarChar(50)
  testMode            Boolean   @default(true)
  senderIds           String    @db.Text
  coverage            String    @db.Text
  balanceAvailable    Float     @default(0)
  balancePurchased    Float     @default(0)
  balanceUpdatedAt    DateTime?
  credentialsVerified Boolean   @default(false)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
}

model Settings {
  id        Int      @id @default(autoincrement())
  shop      String   @db.VarChar(100)
  key       String   @db.VarChar(100)
  value     String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([shop, key])
  @@index([shop])
}

model SmsTemplate {
  id            Int      @id @default(autoincrement())
  shop          String   @db.VarChar(100)
  eventType     String   @db.VarChar(50)
  enabled       Boolean  @default(true)
  templateEn    String   @db.Text
  templateAr    String   @db.Text
  recipientType String   @default("customer") @db.VarChar(20)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([shop, eventType])
  @@index([shop])
}

model SmsLog {
  id               Int      @id @default(autoincrement())
  shop             String   @db.VarChar(100)
  eventType        String   @db.VarChar(50)
  phone            String   @db.VarChar(50)
  recipientType    String   @default("customer") @db.VarChar(20)
  message          String   @db.Text
  senderId         String   @db.VarChar(50)
  status           String   @db.VarChar(20)
  msgId            String?  @db.VarChar(100)
  pointsCharged    Int      @default(0)
  balanceAfter     Float?
  errorCode        String?  @db.VarChar(20)
  errorDescription String?  @db.VarChar(255)
  apiResponse      String?  @db.Text
  testMode         Boolean  @default(false)
  createdAt        DateTime @default(now())

  @@index([shop])
  @@index([createdAt])
  @@index([shop, eventType])
}
