generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Session {
  id            String    @id
  shop          String
  state         String
  isOnline      Boolean   @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean   @default(false)
  locale        String?
  collaborator  Boolean?  @default(false)
  emailVerified Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

model GatewayCredentials {
  id                  Int       @id @default(autoincrement())
  shop                String    @unique
  username            String
  password            String
  senderId            String    @default("")
  testMode            Boolean   @default(true)
  senderIds           String    @db.Text
  coverage            String    @db.Text
  balanceAvailable    Float     @default(0)
  balancePurchased    Float     @default(0)
  balanceUpdatedAt    DateTime?
  credentialsVerified Boolean   @default(false)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
}

model Settings {
  id        Int      @id @default(autoincrement())
  shop      String
  key       String
  value     String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([shop, key])
  @@index([shop])
}

model SmsTemplate {
  id            Int      @id @default(autoincrement())
  shop          String
  eventType     String
  enabled       Boolean  @default(true)
  templateEn    String   @db.Text
  templateAr    String   @db.Text
  recipientType String   @default("customer")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([shop, eventType])
  @@index([shop])
}

model SmsLog {
  id               Int      @id @default(autoincrement())
  shop             String
  eventType        String
  phone            String
  recipientType    String   @default("customer")
  message          String   @db.Text
  senderId         String
  status           String
  msgId            String?
  pointsCharged    Int      @default(0)
  balanceAfter     Float?
  errorCode        String?
  errorDescription String?
  apiResponse      String?  @db.Text
  testMode         Boolean  @default(false)
  createdAt        DateTime @default(now())

  @@index([shop])
  @@index([createdAt])
  @@index([shop, eventType])
}
